{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eva.gc.ca/schemas/risk-control-register.schema.json",
  "title": "Risk Control Register Schema",
  "description": "JSON Schema for validating Risk Control Register documents with YAML front matter",
  "type": "object",
  "required": ["frontmatter", "document_control", "executive_summary", "methodology", "risks", "controls", "kris", "governance"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "required": ["id", "title", "owner", "version", "last_updated"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TMPL-RCR-[0-9]{3}$",
          "description": "Unique template identifier (e.g., TMPL-RCR-001)"
        },
        "title": {
          "type": "string",
          "minLength": 5
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "document_control": {
      "type": "object",
      "required": ["register_id", "classification", "risk_owner", "risk_manager", "system_project", "last_review_date", "next_review_date", "status"],
      "properties": {
        "register_id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "string",
          "enum": ["Protected B", "Protected A", "Unclassified"]
        },
        "risk_owner": {
          "type": "string",
          "minLength": 1
        },
        "risk_manager": {
          "type": "string",
          "minLength": 1
        },
        "system_project": {
          "type": "string",
          "minLength": 1
        },
        "last_review_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "next_review_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Under Review", "Closed"]
        }
      }
    },
    "executive_summary": {
      "type": "object",
      "required": ["risk_profile", "risk_appetite"],
      "properties": {
        "risk_profile": {
          "type": "object",
          "required": ["open_risks", "mitigated_risks", "accepted_risks"],
          "properties": {
            "open_risks": {
              "type": "object",
              "required": ["critical", "high", "medium", "low"],
              "properties": {
                "critical": {
                  "type": "number",
                  "minimum": 0
                },
                "high": {
                  "type": "number",
                  "minimum": 0
                },
                "medium": {
                  "type": "number",
                  "minimum": 0
                },
                "low": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "mitigated_risks": {
              "type": "object"
            },
            "accepted_risks": {
              "type": "object"
            }
          }
        },
        "risk_appetite": {
          "type": "string",
          "minLength": 20,
          "description": "Organization's risk appetite statement"
        }
      }
    },
    "methodology": {
      "type": "object",
      "required": ["framework", "likelihood_scale", "impact_scale", "risk_categories"],
      "properties": {
        "framework": {
          "type": "string",
          "minLength": 1
        },
        "likelihood_scale": {
          "type": "array",
          "minItems": 3
        },
        "impact_scale": {
          "type": "array",
          "minItems": 3
        },
        "risk_categories": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["risk_id", "title", "description", "category", "identified_date", "identified_by", "inherent_assessment", "controls", "residual_assessment", "treatment", "monitoring"],
        "properties": {
          "risk_id": {
            "type": "string",
            "pattern": "^RISK-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 5
          },
          "description": {
            "type": "string",
            "minLength": 20
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "identified_date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "identified_by": {
            "type": "string",
            "minLength": 1
          },
          "inherent_assessment": {
            "type": "object",
            "required": ["likelihood", "impact", "score", "severity"],
            "properties": {
              "likelihood": {
                "type": "number",
                "minimum": 1,
                "maximum": 5
              },
              "impact": {
                "type": "number",
                "minimum": 1,
                "maximum": 5
              },
              "score": {
                "type": "number",
                "minimum": 1,
                "maximum": 25
              },
              "severity": {
                "type": "string",
                "enum": ["Critical", "High", "Medium", "Low", "Very Low"]
              }
            }
          },
          "controls": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "object",
              "required": ["control_id", "description", "type", "owner", "status"],
              "properties": {
                "control_id": {
                  "type": "string",
                  "pattern": "^CTRL-[0-9]{3}-[A-Z]$"
                },
                "description": {
                  "type": "string",
                  "minLength": 10
                },
                "type": {
                  "type": "string",
                  "enum": ["Preventive", "Detective", "Corrective"]
                },
                "owner": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": ["Implemented", "Planned", "In Progress"]
                }
              }
            }
          },
          "residual_assessment": {
            "type": "object",
            "required": ["likelihood", "impact", "score", "severity"],
            "properties": {
              "likelihood": {
                "type": "number",
                "minimum": 1,
                "maximum": 5
              },
              "impact": {
                "type": "number",
                "minimum": 1,
                "maximum": 5
              },
              "score": {
                "type": "number",
                "minimum": 1,
                "maximum": 25
              },
              "severity": {
                "type": "string",
                "enum": ["Critical", "High", "Medium", "Low", "Very Low"]
              }
            }
          },
          "treatment": {
            "type": "object",
            "required": ["strategy", "justification"],
            "properties": {
              "strategy": {
                "type": "string",
                "enum": ["Mitigate", "Accept", "Transfer", "Avoid"]
              },
              "justification": {
                "type": "string",
                "minLength": 10
              }
            }
          },
          "monitoring": {
            "type": "object",
            "required": ["monitoring_method", "monitoring_frequency", "kri", "review_frequency"],
            "properties": {
              "monitoring_method": {
                "type": "string",
                "minLength": 1
              },
              "monitoring_frequency": {
                "type": "string",
                "minLength": 1
              },
              "kri": {
                "type": "string",
                "minLength": 1
              },
              "review_frequency": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "controls": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["control_id", "description", "risks_addressed", "owner", "status"],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^CTRL-[0-9]{3}-[A-Z]$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "risks_addressed": {
            "type": "array",
            "minItems": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["Implemented", "Planned", "In Progress"]
          }
        }
      }
    },
    "kris": {
      "type": "object",
      "required": ["operational", "security", "ai_specific"],
      "properties": {
        "operational": {
          "type": "array",
          "minItems": 1
        },
        "security": {
          "type": "array",
          "minItems": 1
        },
        "ai_specific": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "governance": {
      "type": "object",
      "required": ["review_schedule", "escalation_criteria"],
      "properties": {
        "review_schedule": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["review_type", "frequency", "participants"],
            "properties": {
              "review_type": {
                "type": "string",
                "minLength": 1
              },
              "frequency": {
                "type": "string",
                "minLength": 1
              },
              "participants": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        "escalation_criteria": {
          "type": "array",
          "minItems": 1
        }
      }
    }
  }
}
