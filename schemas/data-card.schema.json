{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eva.gc.ca/schemas/data-card.schema.json",
  "title": "AI Data Card Schema",
  "description": "JSON Schema for validating AI Data Card documents with YAML front matter",
  "type": "object",
  "required": ["frontmatter", "document_control", "dataset_overview", "data_characteristics", "sensitive_data", "representativeness", "access_security", "lifecycle", "lineage", "usage_guidelines", "governance"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "required": ["id", "title", "owner", "version", "last_updated"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TMPL-DC-[0-9]{3}$",
          "description": "Unique template identifier (e.g., TMPL-DC-001)"
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "description": "Title of the data card"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "Data Steward or team responsible"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "document_control": {
      "type": "object",
      "required": ["dataset_id", "classification", "data_steward", "systems_using_data", "last_review_date", "next_review_date", "status"],
      "properties": {
        "dataset_id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "string",
          "enum": ["Protected B", "Protected A", "Unclassified"]
        },
        "data_steward": {
          "type": "string",
          "minLength": 1
        },
        "systems_using_data": {
          "type": "array",
          "minItems": 1
        },
        "last_review_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "next_review_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Archived", "Deprecated"]
        }
      }
    },
    "dataset_overview": {
      "type": "object",
      "required": ["purpose", "dataset_type", "provenance"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 20
        },
        "dataset_type": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["Training Data", "Evaluation Data", "Operational Data", "Retrieval Corpus", "Reference Data"]
          }
        },
        "provenance": {
          "type": "object",
          "required": ["original_source", "collection_method", "collection_date_range", "version"],
          "properties": {
            "original_source": {
              "type": "string",
              "minLength": 1
            },
            "collection_method": {
              "type": "string",
              "minLength": 1
            },
            "collection_date_range": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "data_characteristics": {
      "type": "object",
      "required": ["volume", "schema", "quality"],
      "properties": {
        "volume": {
          "type": "object",
          "required": ["total_records", "total_size", "update_frequency"],
          "properties": {
            "total_records": {
              "type": "number",
              "minimum": 0
            },
            "total_size": {
              "type": "string",
              "minLength": 1
            },
            "update_frequency": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "schema": {
          "type": "object",
          "required": ["fields"],
          "properties": {
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["field_name", "data_type", "required", "pii_sensitive", "classification"],
                "properties": {
                  "field_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "data_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "pii_sensitive": {
                    "type": "boolean"
                  },
                  "classification": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "required": ["completeness", "accuracy", "consistency"],
          "properties": {
            "completeness": {
              "type": "object",
              "required": ["target", "current"],
              "properties": {
                "target": {
                  "type": "string"
                },
                "current": {
                  "type": "string"
                }
              }
            },
            "accuracy": {
              "type": "object",
              "required": ["target", "current"],
              "properties": {
                "target": {
                  "type": "string"
                },
                "current": {
                  "type": "string"
                }
              }
            },
            "consistency": {
              "type": "object",
              "required": ["target", "current"],
              "properties": {
                "target": {
                  "type": "string"
                },
                "current": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "sensitive_data": {
      "type": "object",
      "required": ["pii_inventory", "sensitive_attributes", "data_minimization", "pia"],
      "properties": {
        "pii_inventory": {
          "type": "array",
          "minItems": 0
        },
        "sensitive_attributes": {
          "type": "array",
          "minItems": 0
        },
        "data_minimization": {
          "type": "object",
          "required": ["necessity_assessment"],
          "properties": {
            "necessity_assessment": {
              "type": "string",
              "minLength": 10
            }
          }
        },
        "pia": {
          "type": "object",
          "required": ["completed", "status"],
          "properties": {
            "completed": {
              "type": "boolean"
            },
            "status": {
              "type": "string",
              "enum": ["Yes", "No", "In Progress"]
            }
          }
        }
      }
    },
    "representativeness": {
      "type": "object",
      "required": ["target_population", "coverage", "known_biases", "fairness_assessment"],
      "properties": {
        "target_population": {
          "type": "string",
          "minLength": 10
        },
        "coverage": {
          "type": "object",
          "required": ["geographic", "temporal", "language"],
          "properties": {
            "geographic": {
              "type": "string",
              "minLength": 1
            },
            "temporal": {
              "type": "string",
              "minLength": 1
            },
            "language": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        "known_biases": {
          "type": "array",
          "minItems": 0
        },
        "fairness_assessment": {
          "type": "object",
          "required": ["performed"],
          "properties": {
            "performed": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "access_security": {
      "type": "object",
      "required": ["access_controls", "security_measures", "storage_location"],
      "properties": {
        "access_controls": {
          "type": "array",
          "minItems": 1
        },
        "security_measures": {
          "type": "object",
          "required": ["encryption_at_rest", "encryption_in_transit", "access_logging"],
          "properties": {
            "encryption_at_rest": {
              "type": "string",
              "minLength": 1
            },
            "encryption_in_transit": {
              "type": "string",
              "minLength": 1
            },
            "access_logging": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "storage_location": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["collection", "retention_disposal"],
      "properties": {
        "collection": {
          "type": "object",
          "required": ["collection_method", "collection_frequency", "data_sources"],
          "properties": {
            "collection_method": {
              "type": "string",
              "minLength": 1
            },
            "collection_frequency": {
              "type": "string",
              "minLength": 1
            },
            "data_sources": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        "retention_disposal": {
          "type": "object",
          "required": ["retention_period", "retention_justification", "disposal_method"],
          "properties": {
            "retention_period": {
              "type": "string",
              "minLength": 1
            },
            "retention_justification": {
              "type": "string",
              "minLength": 10
            },
            "disposal_method": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["upstream_dependencies", "downstream_consumers"],
      "properties": {
        "upstream_dependencies": {
          "type": "array",
          "minItems": 0
        },
        "downstream_consumers": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "usage_guidelines": {
      "type": "object",
      "required": ["approved_uses", "prohibited_uses"],
      "properties": {
        "approved_uses": {
          "type": "array",
          "minItems": 1
        },
        "prohibited_uses": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "governance": {
      "type": "object",
      "required": ["regulatory_compliance", "data_governance", "quality_monitoring"],
      "properties": {
        "regulatory_compliance": {
          "type": "array",
          "minItems": 1
        },
        "data_governance": {
          "type": "object",
          "required": ["data_owner", "data_steward", "review_frequency"],
          "properties": {
            "data_owner": {
              "type": "string",
              "minLength": 1
            },
            "data_steward": {
              "type": "string",
              "minLength": 1
            },
            "review_frequency": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "quality_monitoring": {
          "type": "object",
          "required": ["monitoring_method", "monitoring_frequency"],
          "properties": {
            "monitoring_method": {
              "type": "string",
              "minLength": 1
            },
            "monitoring_frequency": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
